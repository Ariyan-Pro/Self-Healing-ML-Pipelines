+++ .gitignore (修改后)
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out
dist/
build/
target/

# Dependencies
.venv/
venv/
.env
.env.local
*.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage and testing
.coverage
coverage/
htmlcov/

# Python specific
.mypy_cache/
.pytest_cache/

# Node.js specific
node_modules/

# Java/Gradle specific
.gradle/